# ─────────────────────────────────────────────────────────
# Beverly Wallet Backend — Environment
# Copy to .env.local and fill values. Never commit .env.local.
# ─────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Redis (BullMQ queue + rate limit)
REDIS_URL=redis://localhost:6379

# Energy backend (existing CRM proxy target)
ENERGY_BACKEND_URL=
ENERGY_BEARER_TOKEN=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_TOKEN_SMS_FROM_NUMBER=
TWILIO_TOKEN_SMS_MESSAGING_SERVICE_SID=

# Postmark (email)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM=Beverly <no-reply@beverly.acoblighting.com>

# Encryption (PII column encryption)
APP_ENCRYPTION_KEY=

# Feature flags
FEATURE_CUSTOMER_WALLET=true
FEATURE_METER_PURCHASE=true
FEATURE_VENDOR_VENDING=true
