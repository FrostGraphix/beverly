{
  "name": "@beverly/wallet-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Beverly Wallet Ecosystem — dedicated Fastify backend service",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.5.0",
    "@fastify/swagger": "^8.14.0",
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.12.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "postmark": "^4.0.4",
    "twilio": "^5.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
