{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    { "path": "/api/cron/refresh-hot", "schedule": "0 6 * * *" },
    { "path": "/api/cron/refresh-hourly", "schedule": "0 12 * * *" },
    { "path": "/api/cron/refresh-daily", "schedule": "0 23 * * *" },
    { "path": "/api/cron/refresh-backfill", "schedule": "0 18 * * *" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/reference?__pathname=/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
